---
title: Home
layout: base.njk
---
<p class="home-intro">everything I make, in one place — poems, lyrics, stories, and box art.</p>

<ul class="entry-list">
{% for item in collections.everything %}
  <li>
    <a href="{{ item.url | url }}">{{ item.data.title }}</a>
    <span class="entry-kind">{{ item.data.kind }}</span>
    <span class="entry-date">{{ item.date | readableDate }}</span>
  </li>
{% endfor %}
</ul>
